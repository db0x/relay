<!doctype html><meta charset="utf-8"><title><%= appName %> — Dokumente</title>
<link rel="stylesheet" href="<%= base %>/static/css/index.css?v=<%= v %>">
<link rel="stylesheet" href="<%= base %>/static/vendor/codemirror.min.css?v=<%= v %>">
<link rel="stylesheet" href="<%= base %>/static/vendor/highlight-github.min.css?v=<%= v %>">
<script defer src="<%= base %>/static/vendor/codemirror.min.js?v=<%= v %>"></script>
<script defer src="<%= base %>/static/vendor/cm-xml.min.js?v=<%= v %>"></script>
<script defer src="<%= base %>/static/vendor/cm-markdown.min.js?v=<%= v %>"></script>
<script defer src="<%= base %>/static/vendor/marked.min.js?v=<%= v %>"></script>
<script defer src="<%= base %>/static/vendor/purify.min.js?v=<%= v %>"></script>
<script defer src="<%= base %>/static/vendor/highlight.min.js?v=<%= v %>"></script>
<script defer src="<%= base %>/static/js/index.js?v=<%= v %>"></script>
<header class="topbar">
    <div class="brand">
      <img src="<%= base %>/static/img/logo.svg" alt="" width="28" height="28">
      <span><%= appName %></span>
    </div>
    <div class="user">
      <% if (hasAvatar) { %>
      <img class="avatar" src="<%= base %>/avatar/<%= encodeURIComponent(me) %>" alt="" width="32" height="32">
      <% } %>
      <span class="uname"><%= user %></span>
      <div class="menu">
        <button type="button" class="iconbtn menu-btn" aria-haspopup="true"
                aria-expanded="false" aria-label="Menü" data-tip="Menü">
          <img src="<%= base %>/static/img/open-menu.svg" alt="" width="16" height="16">
        </button>
        <div class="menu-panel" hidden>
          <button type="button" class="menu-item" data-dialog="dlg-account">Mein Konto</button>
          <% if (isAdmin) { %>
          <button type="button" class="menu-item" data-dialog="dlg-users">Nutzerverwaltung</button>
          <button type="button" class="menu-item" data-dialog="dlg-settings">Einstellungen</button>
          <% } %>
          <a class="menu-item" href="<%= base %>/logout">Abmelden</a>
          <div class="menu-version">Relay v<%= version %></div>
        </div>
      </div>
    </div>
  </header>

<div class="page">
  <% flashes.forEach(function(f){ %>
  <div class="flash <%= f[0] %>"><%= f[1] %></div>
  <% }); %>

  <section class="toolbar">
    <div class="create-group" role="group" aria-label="Neue Datei erstellen">
      <button type="button" class="create-btn" data-create="docx"
              data-tip="Neues Textdokument" aria-label="Neues Textdokument">
        <span class="create-zoom"><img src="<%= base %>/static/img/docx.svg" alt="" width="48" height="48"></span>
      </button>
      <button type="button" class="create-btn" data-create="xlsx"
              data-tip="Neue Tabelle" aria-label="Neue Tabelle">
        <span class="create-zoom"><img src="<%= base %>/static/img/xlsx.svg" alt="" width="48" height="48"></span>
      </button>
      <button type="button" class="create-btn" data-create="pptx"
              data-tip="Neue Präsentation" aria-label="Neue Präsentation">
        <span class="create-zoom"><img src="<%= base %>/static/img/pptx.svg" alt="" width="48" height="48"></span>
      </button>
      <button type="button" class="create-btn" id="note-new"
              data-tip="Neue Notiz" aria-label="Neue Notiz">
        <span class="create-zoom"><img src="<%= base %>/static/img/note.svg" alt="" width="48" height="48"></span>
      </button>
    </div>
    <span class="tool-sep" aria-hidden="true"></span>
    <%# ein Knopf: oeffnet die Dateiauswahl, die Auswahl laedt sofort hoch (index.js) %>
    <form class="upload-form" action="<%= base %>/upload" method="post" enctype="multipart/form-data"
          data-max-mb="<%= maxUploadMb %>">
      <input type="hidden" name="dir" value="<%= curDir %>">
      <input type="file" name="file" accept="<%= uploadAccept %>" hidden>
      <button type="button" class="btn btn-secondary upload-btn">
        <img class="btn-icon" src="<%= base %>/static/img/upload.svg" alt="" width="16" height="16">Hochladen
      </button>
    </form>
    <button type="button" class="btn btn-secondary" data-dialog="dlg-mkdir">
      <img class="btn-icon" src="<%= base %>/static/img/folder.svg" alt="" width="16" height="16">Neuer Ordner
    </button>
  </section>

  <% if (crumbs.length > 1) { %>
  <nav class="crumbs">
    <% crumbs.forEach(function(c, i){ %>
      <% if (i) { %><span class="crumb-sep">/</span><% } %>
      <% if (i === crumbs.length - 1) { %>
      <span class="crumb current"><%= c.label %></span>
      <% } else { %>
      <a class="crumb" href="<%= c.href %>"><%= c.label %></a>
      <% } %>
    <% }); %>
  </nav>
  <% } %>

  <div class="table-wrap">
    <table class="files">
      <thead>
        <tr>
          <% columns.forEach(function(c){ %>
          <th class="<%= c.cls %>">
            <a class="sort<%= c.active ? ' active' : '' %>" href="<%= c.href %>">
              <%= c.label %><span class="arrow"><%= c.arrow %></span>
            </a>
          </th>
          <% }); %>
          <th class="col-actions"></th>
        </tr>
      </thead>
      <tbody>
        <% if (files.length) { files.forEach(function(f, i){ %>
        <tr<%- f.isOwner ? "" : ' class="row-foreign"' %>>
          <td class="col-name">
            <div class="file-cell">
              <img class="ficon" src="<%= base %>/static/img/<%= f.icon %>.svg" alt="" width="28" height="28">
              <span class="fname-wrap">
                <% if (f.isDir) { %>
                <a class="fname" href="<%= base %>/?p=<%= encodeURIComponent(f.relpath) %>"><%= f.label %></a>
                <% } else if (f.isNote) { %>
                <button type="button" class="fname note-open" data-owner="<%= f.owner %>"
                        data-rel="<%= f.relpath %>" data-label="<%= f.label %>"
                        data-canedit="<%= (f.isOwner || f.perm === "edit") ? 1 : 0 %>"><%= f.label %></button>
                <% } else { %>
                <a class="fname" href="<%= base %>/edit/<%= encodeURIComponent(f.owner) %>/<%= encPath(f.relpath) %>"><%= f.label %></a>
                <% } %>
                <% if (f.todo) { %>
                <span class="badge badge-todo<%= f.todo.overdue ? " badge-todo-over" : "" %>">ToDo<%= f.todo.dueLabel ? " · fällig " + f.todo.dueLabel : "" %></span>
                <% } %>
                <% if (!f.isOwner) { %>
                <span class="badge">von <%= f.ownerName %><% if (f.perm === "view") { %> · nur lesen<% } %></span>
                <% } else if (f.shares.length) { %>
                <span class="badge badge-soft share-badge" tabindex="0">geteilt · <%= f.shares.length %>
                  <span class="share-tip" role="tooltip">
                    <% f.shares.forEach(function(s){ %>
                    <span class="share-tip-row">
                      <% if (s.hasAvatar) { %>
                      <img src="<%= base %>/avatar/<%= encodeURIComponent(s.target) %>" alt="" width="22" height="22">
                      <% } else { %>
                      <span class="share-tip-fallback"><%= (s.display_name || s.target).trim().charAt(0).toUpperCase() %></span>
                      <% } %>
                      <span class="share-tip-name"><%= s.display_name %></span>
                      <span class="share-tip-perm"><%= s.perm === "edit" ? "Bearbeiten" : "Nur lesen" %></span>
                    </span>
                    <% }); %>
                  </span>
                </span>
                <% } %>
              </span>
            </div>
          </td>
          <td class="col-size"><%= f.size %></td>
          <td class="col-date"><%= f.modified %></td>
          <td class="col-actions">
            <%# alle Aktionen in EINEM Kontextmenue pro Zeile (Kebab-Knopf) %>
            <div class="row-menu">
              <button type="button" class="iconbtn row-menu-btn" aria-haspopup="true"
                      aria-expanded="false" data-tip="Aktionen" aria-label="Aktionen">
                <img src="<%= base %>/static/img/open-menu.svg" alt="" width="16" height="16">
              </button>
              <div class="menu-panel row-menu-panel" hidden>
                <% if (f.isDir) { %>
                <form class="del-form" action="<%= base %>/rmdir/<%= encPath(f.relpath) %>" method="post"
                      data-confirm="Ordner „<%= f.label %>“ löschen? Das geht nur, wenn er leer ist.">
                  <input type="hidden" name="dir" value="<%= curDir %>">
                  <button class="menu-item menu-item-ico menu-item-danger">
                    <img src="<%= base %>/static/img/delete.svg" alt="" width="16" height="16">Löschen
                  </button>
                </form>
                <% } else { %>
                <a class="menu-item menu-item-ico" href="<%= base %>/download/<%= encodeURIComponent(f.owner) %>/<%= encPath(f.relpath) %>">
                  <img src="<%= base %>/static/img/download.svg" alt="" width="16" height="16">Herunterladen
                </a>
                <% if (f.isOwner) { %>
                <button type="button" class="menu-item menu-item-ico" data-dialog="dlg-move-<%= i %>">
                  <img src="<%= base %>/static/img/move.svg" alt="" width="16" height="16">Verschieben
                </button>
                <button type="button" class="menu-item menu-item-ico" data-dialog="dlg-share-<%= i %>">
                  <img src="<%= base %>/static/img/share.svg" alt="" width="16" height="16">Freigeben
                </button>
                <form class="del-form" action="<%= base %>/delete/<%= encodeURIComponent(f.owner) %>/<%= encPath(f.relpath) %>" method="post"
                      data-confirm="„<%= f.label %>“ wirklich löschen? Das lässt sich nicht rückgängig machen.">
                  <input type="hidden" name="dir" value="<%= curDir %>">
                  <button class="menu-item menu-item-ico menu-item-danger">
                    <img src="<%= base %>/static/img/delete.svg" alt="" width="16" height="16">Löschen
                  </button>
                </form>
                <% } %>
                <% } %>
              </div>
            </div>
          </td>
        </tr>
        <% }); } else { %>
        <tr><td class="empty" colspan="4">Dieser Ordner ist leer — oben eine Datei anlegen oder hochladen.</td></tr>
        <% } %>
      </tbody>
    </table>
  </div>

  <% if (files.some(function(f){ return !f.isOwner; })) { %>
  <%# Fusszeile mit Filter: nur sichtbar, wenn es ueberhaupt Freigaben gibt %>
  <footer class="list-footer">
    <label class="switch-label">
      <input type="checkbox" id="own-only">
      <span class="switch-ui" aria-hidden="true"></span>
      <span class="switch-text">Nur eigene Dateien</span>
    </label>
  </footer>
  <% } %>

  <% files.forEach(function(f, i){ if (!f.isOwner || f.isDir) return; %>
  <dialog id="dlg-share-<%= i %>" class="dialog">
    <header class="dialog-head">
      <img src="<%= base %>/static/img/share.svg" alt="" width="22" height="22">
      <h2>„<%= f.label %>“ freigeben</h2>
      <form method="dialog">
        <button class="dialog-x" aria-label="Schließen">×</button>
      </form>
    </header>
    <div class="sharebox">
      <% if (f.shares.length) { %>
      <span class="dialog-label">Bereits freigegeben für</span>
      <ul class="share-list">
        <% f.shares.forEach(function(s){ %>
        <li>
          <span><%= s.display_name %>
            <span class="muted">· <%= s.perm === "edit" ? "Bearbeiten" : "Nur lesen" %></span>
          </span>
          <form class="unshare-form" action="<%= base %>/unshare/<%= encPath(f.relpath) %>" method="post"
                data-confirm="Freigabe für <%= s.display_name %> entziehen?">
            <input type="hidden" name="dir" value="<%= curDir %>">
            <input type="hidden" name="target" value="<%= s.target %>">
            <button class="btn btn-secondary btn-sm">entziehen</button>
          </form>
        </li>
        <% }); %>
      </ul>
      <% } else { %>
      <p class="muted">Noch für niemanden freigegeben.</p>
      <% } %>

      <% if (f.availableUsers.length) { %>
      <%# Aktions-Button (dialog-action, nicht dialog-submit): die Vorauswahl
          ist bereits gueltig, der Button darf nie ausgegraut sein %>
      <form class="stack-form share-add" action="<%= base %>/share/<%= encPath(f.relpath) %>" method="post">
        <input type="hidden" name="dir" value="<%= curDir %>">
        <label class="dialog-label" for="share-target-<%= i %>">Freigeben für</label>
        <select class="field" name="target" id="share-target-<%= i %>">
          <% f.availableUsers.forEach(function(u){ %>
          <option value="<%= u.username %>"><%= u.display_name %></option>
          <% }); %>
        </select>
        <label class="dialog-label" for="share-perm-<%= i %>">Berechtigung</label>
        <select class="field" name="perm" id="share-perm-<%= i %>">
          <option value="edit">Bearbeiten</option>
          <option value="view">Nur lesen</option>
        </select>
        <button class="btn btn-sm dialog-action">Freigeben</button>
      </form>
      <% } else { %>
      <p class="muted">Alle anderen Nutzer haben bereits Zugriff.</p>
      <% } %>
    </div>
  </dialog>

  <dialog id="dlg-move-<%= i %>" class="dialog">
    <header class="dialog-head">
      <img src="<%= base %>/static/img/move.svg" alt="" width="22" height="22">
      <h2>„<%= f.label %>“ verschieben</h2>
      <form method="dialog">
        <button class="dialog-x" aria-label="Schließen">×</button>
      </form>
    </header>
    <% var moveTargets = allDirs.filter(function(d){ return d !== curDir; }); %>
    <% if (curDir === "" && !moveTargets.length) { %>
    <p class="muted dialog-hint">Es gibt noch keine Ordner — erst über „Neuer Ordner“ einen anlegen.</p>
    <% } else { %>
    <form class="stack-form" action="<%= base %>/move/<%= encPath(f.relpath) %>" method="post">
      <input type="hidden" name="dir" value="<%= curDir %>">
      <label class="dialog-label" for="move-to-<%= i %>">Zielordner</label>
      <select class="field" name="to" id="move-to-<%= i %>">
        <% if (curDir !== "") { %>
        <option value="">Meine Dateien (oberste Ebene)</option>
        <% } %>
        <% moveTargets.forEach(function(d){ %>
        <option value="<%= d %>"><%= d %></option>
        <% }); %>
      </select>
      <button class="btn btn-sm dialog-action">Verschieben</button>
    </form>
    <% } %>
  </dialog>
  <% }); %>

  <%# Hover-Vorschau fuer Notizen in der Dateiliste (index.js befuellt) %>
  <div class="note-tip md-render" id="note-tip" aria-hidden="true"></div>

  <%# gemeinsamer Backdrop aller Dialoge — ::backdrop gibt es nur fuer modale
      Dialoge, die hier bewusst nicht genutzt werden (siehe index.js) %>
  <div class="dlg-backdrop" id="dlg-backdrop"></div>

  <%# Markdown-Notiz-Editor: modaler Dialog, fuellt 70% der Seite (index.js) %>
  <dialog id="dlg-note" class="dialog dialog-note">
    <header class="dialog-head">
      <img src="<%= base %>/static/img/note.svg" alt="" width="22" height="22">
      <h2 id="dlg-note-title">Neue Notiz</h2>
      <form method="dialog">
        <button class="dialog-x" aria-label="Schließen">×</button>
      </form>
    </header>
    <form class="note-form" id="note-form" method="post" action="<%= base %>/notes/create">
      <input type="hidden" name="dir" value="<%= curDir %>">
      <div class="note-main">
        <%# im Ansichtsmodus: Stift auf dem Panel wechselt ins Bearbeiten %>
        <button type="button" class="iconbtn note-edit-btn" id="note-edit"
                data-tip="Bearbeiten" aria-label="Bearbeiten" hidden>
          <img src="<%= base %>/static/img/edit.svg" alt="" width="16" height="16">
        </button>
        <div class="note-editor-pane">
          <div class="note-toolbar" id="note-toolbar" role="toolbar" aria-label="Formatierung">
            <button type="button" class="note-tb" data-md="bold" data-tip="Fett (Strg+B)" aria-label="Fett">
              <img src="<%= base %>/static/img/toolbar/md-bold.svg" alt="" width="24" height="24">
            </button>
            <button type="button" class="note-tb" data-md="italic" data-tip="Kursiv (Strg+I)" aria-label="Kursiv">
              <img src="<%= base %>/static/img/toolbar/md-italic.svg" alt="" width="24" height="24">
            </button>
            <button type="button" class="note-tb" data-md="strike" data-tip="Durchgestrichen" aria-label="Durchgestrichen">
              <img src="<%= base %>/static/img/toolbar/md-strike.svg" alt="" width="24" height="24">
            </button>
            <span class="note-tb-sep" aria-hidden="true"></span>
            <button type="button" class="note-tb" data-md="h1" data-tip="Überschrift 1" aria-label="Überschrift 1">
              <img src="<%= base %>/static/img/toolbar/md-h1.svg" alt="" width="24" height="24">
            </button>
            <button type="button" class="note-tb" data-md="h2" data-tip="Überschrift 2" aria-label="Überschrift 2">
              <img src="<%= base %>/static/img/toolbar/md-h2.svg" alt="" width="24" height="24">
            </button>
            <button type="button" class="note-tb" data-md="h3" data-tip="Überschrift 3" aria-label="Überschrift 3">
              <img src="<%= base %>/static/img/toolbar/md-h3.svg" alt="" width="24" height="24">
            </button>
            <span class="note-tb-sep" aria-hidden="true"></span>
            <button type="button" class="note-tb" data-md="ul" data-tip="Aufzählung" aria-label="Aufzählung">
              <img src="<%= base %>/static/img/toolbar/md-ul.svg" alt="" width="24" height="24">
            </button>
            <button type="button" class="note-tb" data-md="ol" data-tip="Nummerierte Liste" aria-label="Nummerierte Liste">
              <img src="<%= base %>/static/img/toolbar/md-ol.svg" alt="" width="24" height="24">
            </button>
            <button type="button" class="note-tb" data-md="task" data-tip="Checkliste" aria-label="Checkliste">
              <img src="<%= base %>/static/img/toolbar/md-task.svg" alt="" width="24" height="24">
            </button>
            <button type="button" class="note-tb" data-md="quote" data-tip="Zitat" aria-label="Zitat">
              <img src="<%= base %>/static/img/toolbar/md-quote.svg" alt="" width="24" height="24">
            </button>
            <span class="note-tb-sep" aria-hidden="true"></span>
            <button type="button" class="note-tb" data-md="codeblock" data-tip="Code-Block" aria-label="Code-Block">
              <img src="<%= base %>/static/img/toolbar/md-codeblock.svg" alt="" width="24" height="24">
            </button>
            <button type="button" class="note-tb" data-md="code" data-tip="Code" aria-label="Code">
              <img src="<%= base %>/static/img/toolbar/md-code.svg" alt="" width="24" height="24">
            </button>
            <button type="button" class="note-tb" data-md="link" data-tip="Link" aria-label="Link">
              <img src="<%= base %>/static/img/toolbar/md-link.svg" alt="" width="24" height="24">
            </button>
            <button type="button" class="note-tb" data-md="hr" data-tip="Trennlinie" aria-label="Trennlinie">
              <img src="<%= base %>/static/img/toolbar/md-hr.svg" alt="" width="24" height="24">
            </button>
          </div>
          <textarea class="note-text" name="md" spellcheck="false"
                    aria-label="Markdown-Inhalt der Notiz"></textarea>
        </div>
        <div class="note-splitter" id="note-splitter" role="separator"
             aria-orientation="vertical" aria-label="Aufteilung anpassen"></div>
        <div class="note-preview md-render" id="note-preview" aria-label="Vorschau der Notiz"></div>
      </div>
      <%# Kompaktes, horizontales Edit-Panel — Icons (users/place) markieren die
          Abschnitte wie in der Lese-Ansicht, alles fliesst in einer Zeile und
          bricht bei Bedarf um (bewusst nicht in die Hoehe gestapelt) %>
      <div class="note-details" id="note-details">
        <span class="note-detail-group">
          <label class="switch-label">
            <input type="checkbox" id="note-todo" name="is_todo" value="1">
            <span class="switch-ui" aria-hidden="true"></span>
            <span class="switch-text">ToDo</span>
          </label>
          <input type="date" class="field field-sm" name="due_date" id="note-due"
                 aria-label="Fällig am" hidden>
        </span>

        <%# Personen: ein Chip-Feld mit Autocomplete aus den bekannten Nutzern
            (data-known), das ebenso Freitext fuer Unbekannte annimmt (index.js).
            Die versteckten Felder people_known/people_extra werden aus dem
            Chip-Zustand synchronisiert. %>
        <span class="note-detail-group note-people-field" id="note-people-field"
              data-known="<%= JSON.stringify(knownUsers) %>">
          <img class="note-summary-icon" src="<%= base %>/static/img/users.svg"
               alt="Betroffene Personen" width="16" height="16">
          <span class="chips" id="note-people-chips">
            <input type="text" class="chips-input" id="note-people-input"
                   aria-label="Betroffene Personen" placeholder="Person …" autocomplete="off">
          </span>
          <span id="note-people-hidden"></span>
        </span>

        <span class="note-detail-group">
          <img class="note-summary-icon" src="<%= base %>/static/img/place.svg"
               alt="Ort" width="16" height="16">
          <input class="field field-sm" name="ort" id="note-ort"
                 aria-label="Ort" placeholder="Ort">
        </span>
      </div>
      <%# Lese-Ansicht der Details: nur sichtbar, wenn etwas gesetzt ist —
          befuellt index.js beim Oeffnen aus den Notiz-Metadaten %>
      <div class="note-view-summary" id="note-view-summary" hidden></div>
      <div class="note-foot">
        <span class="note-status" id="note-status" aria-live="polite"></span>
        <button class="btn btn-sm" id="note-save">Speichern</button>
      </div>
    </form>
    <%# unsichtbare Griffecke zum Skalieren (index.js) %>
    <div class="note-resize" id="note-resize" aria-hidden="true"></div>
  </dialog>

  <dialog id="dlg-create" class="dialog">
    <header class="dialog-head">
      <img id="dlg-create-icon" src="<%= base %>/static/img/docx.svg" alt="" width="22" height="22">
      <h2 id="dlg-create-title">Neue Datei</h2>
      <form method="dialog">
        <button class="dialog-x" aria-label="Schließen">×</button>
      </form>
    </header>
    <form class="stack-form" action="<%= base %>/create" method="post">
      <input type="hidden" name="dir" value="<%= curDir %>">
      <input type="hidden" name="ext" id="dlg-create-ext" value="docx">
      <label class="dialog-label" for="dlg-create-name" id="dlg-create-name-label">Name der Datei</label>
      <input class="field" name="name" id="dlg-create-name"
             placeholder="Name der neuen Datei" required autocomplete="off">
      <label class="dialog-label" for="dlg-create-lang">Sprache des Dokuments</label>
      <select class="field" name="lang" id="dlg-create-lang"
              data-default="<%= docLangDefault %>">
        <% docLangs.forEach(function(l){ %>
        <option value="<%= l.code %>"<%= l.code === docLangDefault ? " selected" : "" %>><%= l.label %></option>
        <% }); %>
      </select>
      <button class="btn btn-sm dialog-submit">Erstellen</button>
    </form>
  </dialog>

  <dialog id="dlg-mkdir" class="dialog">
    <header class="dialog-head">
      <img src="<%= base %>/static/img/folder.svg" alt="" width="22" height="22">
      <h2>Neuer Ordner</h2>
      <form method="dialog">
        <button class="dialog-x" aria-label="Schließen">×</button>
      </form>
    </header>
    <form class="stack-form" action="<%= base %>/mkdir" method="post">
      <input type="hidden" name="dir" value="<%= curDir %>">
      <input class="field" name="name" placeholder="Name des Ordners" required autocomplete="off">
      <button class="btn btn-sm dialog-submit">Anlegen</button>
    </form>
  </dialog>

  <% if (isAdmin) { %>
  <dialog id="dlg-users" class="dialog dialog-xwide">
    <header class="dialog-head">
      <img src="<%= base %>/static/img/logo.svg" alt="" width="22" height="22">
      <h2>Nutzerverwaltung</h2>
      <form method="dialog">
        <button class="dialog-x" aria-label="Schließen">×</button>
      </form>
    </header>
    <div class="users-wrap">
      <table class="users-table">
        <thead>
          <tr><th>Nutzer</th><th class="num">Speicher</th><th>Status</th><th></th></tr>
        </thead>
        <tbody>
          <% allUsers.forEach(function(u){ %>
          <tr>
            <td>
              <div class="user-cell">
                <% if (u.hasAvatar) { %>
                <img class="user-pic" src="<%= base %>/avatar/<%= encodeURIComponent(u.username) %>" alt="" width="28" height="28">
                <% } else { %>
                <span class="user-pic user-pic-fallback"><%= (u.display_name || u.username).trim().charAt(0).toUpperCase() %></span>
                <% } %>
                <span class="user-names">
                  <span><%= u.display_name %></span>
                  <span class="muted"><%= u.username %></span>
                </span>
              </div>
            </td>
            <td class="num muted"><%= u.size %></td>
            <td>
              <% if (u.is_admin) { %><span class="badge">Admin</span><% } %>
              <% if (u.locked) { %><span class="badge badge-lock">gesperrt</span><% } %>
            </td>
            <td class="users-actions">
              <% if (u.username !== me) { %>
              <%# gesperrte Nutzer koennen keine Admins werden — Knopf ausblenden %>
              <% if (u.is_admin || !u.locked) { %>
              <form class="unshare-form" action="<%= base %>/users/admin" method="post"
                    <% if (u.is_admin) { %>data-confirm="<%= u.display_name %> die Admin-Rechte entziehen?"<% } %>>
                <input type="hidden" name="target" value="<%= u.username %>">
                <input type="hidden" name="value" value="<%= u.is_admin ? 0 : 1 %>">
                <button class="btn btn-secondary btn-sm">
                  <%= u.is_admin ? "Admin entziehen" : "zum Admin machen" %>
                </button>
              </form>
              <% } %>
              <%# Admins koennen nicht gesperrt werden — Knopf ausblenden %>
              <% if (u.locked || !u.is_admin) { %>
              <form class="unshare-form" action="<%= base %>/users/lock" method="post"
                    <% if (!u.locked) { %>data-confirm="<%= u.display_name %> sperren? Login, Sitzungen und API-Token sind dann blockiert."<% } %>>
                <input type="hidden" name="target" value="<%= u.username %>">
                <input type="hidden" name="value" value="<%= u.locked ? 0 : 1 %>">
                <button class="btn btn-secondary btn-sm<%= u.locked ? '' : ' btn-sm-danger' %>">
                  <%= u.locked ? "entsperren" : "sperren" %>
                </button>
              </form>
              <% } %>
              <%# loeschen nur fuer Nicht-Admins (erst Rechte entziehen) %>
              <% if (!u.is_admin) { %>
              <form class="unshare-form" action="<%= base %>/users/delete" method="post"
                    data-confirm="<%= u.display_name %> endgültig löschen? ALLE Dateien, Freigaben und das Profil werden unwiderruflich entfernt.">
                <input type="hidden" name="target" value="<%= u.username %>">
                <button class="iconbtn iconbtn-danger" data-tip="Nutzer löschen" aria-label="Nutzer löschen">
                  <img src="<%= base %>/static/img/delete.svg" alt="" width="16" height="16">
                </button>
              </form>
              <% } %>
              <% } %>
            </td>
          </tr>
          <% }); %>
        </tbody>
      </table>

      <form class="stack-form user-create" action="<%= base %>/users/create" method="post" autocomplete="off">
        <span class="dialog-label">Neuen Nutzer anlegen</span>
        <div class="user-create-row">
          <input class="field grow" name="username" placeholder="Nutzername (Login)" required
                 aria-label="Nutzername (Login)">
          <input class="field grow" name="display" placeholder="Anzeigename (optional)"
                 aria-label="Anzeigename (optional)">
          <input class="field grow" name="password" type="password"
                 placeholder="Startpasswort (min. 8 Zeichen)" required minlength="8"
                 autocomplete="new-password" aria-label="Startpasswort">
        </div>
        <div class="user-create-foot">
          <label class="check"><input type="checkbox" name="admin" value="1"> Admin</label>
          <button class="btn btn-sm">Nutzer anlegen</button>
        </div>
      </form>
    </div>
  </dialog>
  <% } %>

  <%# Hinweis-Dialog (eine OK-Taste), z.B. "Datei zu gross" — befuellt von index.js %>
  <dialog id="dlg-notice" class="dialog">
    <header class="dialog-head" id="dlg-notice-head">
      <img id="dlg-notice-icon" src="" alt="" width="22" height="22" hidden>
      <h2 id="dlg-notice-title">Hinweis</h2>
      <form method="dialog">
        <button class="dialog-x" aria-label="Schließen">×</button>
      </form>
    </header>
    <p class="confirm-text" id="dlg-notice-text"></p>
    <div class="confirm-btns">
      <form method="dialog">
        <button class="btn btn-sm">Verstanden</button>
      </form>
    </div>
  </dialog>

  <%# gemeinsamer Bestaetigungs-Dialog fuer alle form[data-confirm] (index.js) %>
  <dialog id="dlg-confirm" class="dialog">
    <header class="dialog-head">
      <h2>Bitte bestätigen</h2>
      <form method="dialog">
        <button class="dialog-x" aria-label="Abbrechen">×</button>
      </form>
    </header>
    <p class="confirm-text" id="dlg-confirm-text"></p>
    <div class="confirm-btns">
      <button type="button" class="btn btn-secondary btn-sm" id="dlg-confirm-cancel" autofocus>Abbrechen</button>
      <button type="button" class="btn btn-danger btn-sm" id="dlg-confirm-ok">Bestätigen</button>
    </div>
  </dialog>

  <% if (isAdmin) { %>
  <dialog id="dlg-settings" class="dialog dialog-xwide">
    <header class="dialog-head">
      <img src="<%= base %>/static/img/edit.svg" alt="" width="22" height="22">
      <h2>Einstellungen</h2>
      <form method="dialog">
        <button class="dialog-x" aria-label="Schließen">×</button>
      </form>
    </header>
    <section class="account-section">
      <h3>Sprachen im „Neue Datei“-Dialog</h3>
      <p class="muted dialog-hint">Nur angehakte Sprachen erscheinen in der Auswahl.
        Deutsch (Deutschland) ist die Vorgabe und lässt sich nicht ausblenden.</p>
      <form class="stack-form" action="<%= base %>/settings/langs" method="post">
        <div class="lang-list">
          <% settingsLangs.forEach(function(l){ %>
          <label class="check">
            <input type="checkbox" name="visible" value="<%= l.code %>"
                   <%= l.hidden ? "" : "checked" %> <%= l.code === docLangDefault ? "disabled" : "" %>>
            <%= l.label %>
          </label>
          <% }); %>
        </div>
        <button class="btn btn-sm dialog-submit">Speichern</button>
      </form>
    </section>
  </dialog>
  <% } %>

  <dialog id="dlg-account" class="dialog dialog-wide">
    <header class="dialog-head">
      <% if (hasAvatar) { %>
      <img class="avatar" src="<%= base %>/avatar/<%= encodeURIComponent(me) %>" alt="" width="22" height="22">
      <% } else { %>
      <img src="<%= base %>/static/img/logo.svg" alt="" width="22" height="22">
      <% } %>
      <h2>Mein Konto <span class="muted">· <%= user %></span></h2>
      <form method="dialog">
        <button class="dialog-x" aria-label="Schließen">×</button>
      </form>
    </header>

    <section class="account-section avatar-section">
      <%# Avatar zentriert; der Stift unten rechts oeffnet die Dateiauswahl,
          die Auswahl laedt sofort hoch (index.js) %>
      <form id="avatar-upload" class="avatar-wrap" action="<%= base %>/avatar"
            method="post" enctype="multipart/form-data">
        <% if (hasAvatar) { %>
        <img class="avatar-preview" src="<%= base %>/avatar/<%= encodeURIComponent(me) %>" alt="Aktuelles Profilbild" width="96" height="96">
        <% } else { %>
        <div class="avatar-preview avatar-empty">kein Bild</div>
        <% } %>
        <input type="file" name="file" accept="image/png,image/jpeg,image/webp" hidden>
        <button type="button" class="avatar-edit" data-tip="Profilbild ändern" aria-label="Profilbild ändern">
          <img src="<%= base %>/static/img/edit.svg" alt="" width="14" height="14">
        </button>
      </form>
    </section>

    <section class="account-section">
      <%# EIN Formular fuer die Profilfelder — EIN Speichern-Button %>
      <form class="stack-form" action="<%= base %>/profile" method="post">
        <label class="dialog-label" for="acc-display">Anzeigename</label>
        <%# pattern verlangt mind. ein Nicht-Leerzeichen — "   " zaehlt nicht als Name %>
        <input class="field" name="display" id="acc-display" value="<%= user %>" required maxlength="60"
               pattern=".*\S.*" title="Der Anzeigename darf nicht leer sein."
               placeholder="Anzeigename" autocomplete="name">
        <label class="dialog-label" for="acc-email">E-Mail-Adresse · optional</label>
        <%# leer erlaubt (entfernt die Adresse); wenn gefuellt, muss das Format
            stimmen — gleiches Regex wie serverseitig in routes/auth.js %>
        <input class="field<%= emailError ? " field-invalid" : "" %>" name="email" id="acc-email" type="email"
               value="<%= email %>" placeholder="name@beispiel.de" maxlength="120"
               autocomplete="email" pattern="[^\s@]+@[^\s@]+\.[^\s@]+"
               title="Bitte eine gültige E-Mail-Adresse eingeben (oder das Feld leeren).">
        <button class="btn btn-sm dialog-submit">Speichern</button>
      </form>
    </section>

    <details class="account-section account-fold"<%- pwError ? " open" : "" %>>
      <summary><h3>Passwort ändern</h3></summary>
      <form class="stack-form" id="pw-form" action="<%= base %>/password" method="post">
        <input class="field<%= pwError === "old" ? " field-invalid" : "" %>" name="old"
               type="password" placeholder="Aktuelles Passwort"
               autocomplete="current-password" required>
        <input class="field<%= pwError === "new" ? " field-invalid" : "" %>" name="new1"
               type="password" placeholder="Neues Passwort (min. 8 Zeichen)"
               autocomplete="new-password" required minlength="8">
        <input class="field<%= pwError === "new" ? " field-invalid" : "" %>" name="new2"
               type="password" placeholder="Neues Passwort (wiederholen)"
               autocomplete="new-password" required minlength="8">
        <button class="btn btn-sm dialog-submit">Ändern</button>
      </form>
    </details>

    <details class="account-section account-fold">
      <summary><h3>API-Token <span class="muted">· für Sync / Skripte</span></h3></summary>
      <div class="tokbox">
        <code id="tok"><%= api_token %></code>
        <div class="tokhint">Wie ein Passwort behandeln — nicht weitergeben.
          Nutzung: <code>Authorization: Bearer &lt;token&gt;</code> gegen <code>/api/files</code>.</div>
        <form class="reset-form" action="<%= base %>/token/reset" method="post"
              data-confirm="Neues Token erzeugen? Bestehende Sync-Verbindungen mit dem alten Token funktionieren dann nicht mehr.">
          <button class="btn btn-danger btn-sm">neu erzeugen</button>
        </form>
      </div>
    </details>
  </dialog>
</div>
