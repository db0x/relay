# Relay configuration — copy to .env and adjust. The real .env is gitignored
# (secrets!); this template documents all variables.

# LAN address/hostname of this machine; used to build PUBLIC_DS_URL
# (browser -> DocumentServer): http://<SERVER_HOST>:<DS_PORT>
SERVER_HOST=192.168.1.10

# Display name of this instance in the UI (title, header, login). Default: Relay
INSTANCE_NAME=Relay

# Sub-path behind a reverse proxy, e.g. /relay for http://moria/relay.
# Leave empty when Relay runs at the root.
BASE_PATH=

# Host ports: web UI and DocumentServer
# (5000 instead of 8080 as the DS default — 8080 is often taken already)
UI_PORT=5001
DS_PORT=5000

# Browser-facing URL of the DocumentServer. Empty = http://<SERVER_HOST>:<DS_PORT>.
# Behind nginx with the /ds proxy (see deploy/nginx-relay.conf.example):
# PUBLIC_DS_URL=http://moria/ds
PUBLIC_DS_URL=

# Bind address of the container ports. Default 0.0.0.0 (reachable on the LAN).
# Behind nginx on the same host: 127.0.0.1 — then only port 80 is exposed.
BIND_ADDR=

# Host directories for user files and the user database
# (default: ./documents and ./state inside the project folder).
# On a server e.g. /srv/relay/documents and /srv/relay/state.
DOCUMENTS_DIR=./documents
STATE_DIR=./state

# Secrets — roll ALL four anew for every fresh installation:
#   openssl rand -hex 32
JWT_SECRET=CHANGE_ME
SECURE_LINK_SECRET=CHANGE_ME
FILE_SECRET=CHANGE_ME
SESSION_SECRET=CHANGE_ME
